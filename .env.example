###############################################################################
# FusionPBX — environment configuration
# Copy to .env and adjust before running ./scripts/start.sh
###############################################################################

# Container image tags (built locally by ./scripts/build.sh)
IMAGE_NAME=usyeimar/fusionpbx:latest
FREESWITCH_IMAGE=usyeimar/freeswitch:latest

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fusionpbx
DB_USER=fusionpbx
DB_PASS=change_me_to_a_strong_password

# Timezone
TZ=America/Bogota
